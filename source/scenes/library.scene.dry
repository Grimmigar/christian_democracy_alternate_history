@factions
go-to: menu

**Internal factions of the CDU/CSU**

Overall dissent: [+ dissent_percent : dissent +]

**Nationalists**

The Nationalists within our Party, supporting cooperation with the AfD. While not being outright fascist, they do support more hard-right policies within the CDU.

Strength: [+ left_strength : strength +]

Dissent: [+ left_dissent : dissent +]

**Conservatives**

The Conservatives in the CDU seek a more moderate course of conservatism, preserving tradition in these changing times.

Strength: [+ center_strength : strength +]

Dissent: [+ center_dissent : dissent +]

**Christian-social**

The Christian Democratic Employees' Association is our main trade union, many of it's members support expanding worker's rights and welfare.

Strength: [+ labor_strength : strength +]

Dissent: [+ labor_dissent : dissent +]

**Liberals**

Liberals in the CDU are the faction seeking to implement more liberal social policy while supporting a market course. They support cooperation with Liberal Parties.

Strength: [+ reformist_strength : strength +]

Dissent: [+ reformist_dissent : dissent +]


@figures
title: Figures and Charts
go-to: menu
on-arrival: z_minus_bvp_r = z_r - 3;
on-display: {!
data = [
    {
        "id": "linke",
        "legend": "Linke",
        "name": "Linke",
        "seats": Q.linke_r*5,
    },
    {
        "id": "spd",
        "legend": "SPD",
        "name": "SPD",
        "seats": Q.spd_r*5,
    },
    {
        "id": "greens",
        "legend": "Greens",
        "name": "Greens",
        "seats": Q.ddp_r*5,
    },
    {
        "id": "cdu",
        "legend": "CDU",
        "name": "CDU",
        "seats": (Q.cdu_r - 3)*5,
    },
    {
        "id": "csu",
        "legend": "CSU",
        "name": "CSU",
        "seats": 3*5,
    },
    {
        "id": "fdp",
        "legend": "FDP",
        "name": "FDP",
        "seats": Q.fdp_r*5,
    },
    {
        "id": "afd",
        "legend": "AfD",
        "name": "AfD",
        "seats": Q.afd_r*5,
    },
]);
if (d3 && window) {
    // get screen width
    var width = 500;
    var height = 500;
    var screenWidth = document.getElementById('content').offsetWidth;
    if (screenWidth < width - 50) {
        width = screenWidth - 50;
        height = width;
        document.getElementById("reichstag").style.height = screenWidth/2 + "px";
    }
    var parliament = d3.parliament();
    parliament.width(width).height(height).innerRadiusCoef(0.4);
    parliament.enter.fromCenter(true).smallToBig(true);
    parliament.exit.toCenter(false).bigToSmall(true);
    d3.select("#reichstag").datum(data).call(parliament);

    var lines = d3.linegraph(false, false,
            Q.parties,
            {'cdu': '#000', 'linke': '#8B0000', 'spd': '#E3000F', 'greens': '#DCCA4A', 'fdp': '#D5AC27', 'afd': '#3f7bc1'},
            {'cdu': 'CDU/CSU', 'linke': 'Die Linke', 'spd': 'SPD', 'greens': 'Greens', 'fdp': 'FDP', 'afd': 'AfD'});
    lines.width(width).height(400);
    //var svg = lines(Q.election_records);
    if (Q.election_records.length > 0) {
        d3.select("#election_history").datum(Q.election_records).call(lines);
    }
    //document.getElementById('election_history').innerHTML = svg.outerHTML;

    // economic stats
    var minInflation = d3.min(Q.economic_records, d => d.inflation);
    var maxUnemployment = d3.max(Q.economic_records, d => d.unemployment);
    var lines_3 = d3.linegraph(true, true, ['inflation', 'unemployment'],
            {'inflation': '#0000FF', 'unemployment': '#FF0000'},
            {'inflation': 'Inflation', 'unemployment': 'Unemployment'},
            maxUnemployment + 5, minInflation - 5, 21);
    lines_3.width(width).height(300);
    d3.select("#economic_history").datum(Q.economic_records).call(lines_3);
}
!}

